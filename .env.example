# ─── GenAI Platform Environment Variables ───
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── PostgreSQL ───
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/genai_platform

# ─── LLM Configuration ───
# Any OpenAI-compatible endpoint works (vLLM, Ollama, OpenAI, etc.)
LLM_BASE_URL=http://your-llm-server:port/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL_NAME=/model

# ─── HuggingFace (optional — only for gated embedding models) ───
HF_TOKEN=

# ─── ChromaDB & Embeddings ───
CHROMA_DB_PATH=/app/data_files/chroma_db
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
UPLOAD_DIR=/app/data_files/uploads

# ─── Redis ───
REDIS_HOST=redis
REDIS_PORT=6379

# ─── CORS (comma-separated origins) ───
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
